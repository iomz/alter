#!/usr/bin/env sh
set -eu

plugin_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)

case "${1:-}" in
  manifest)
    cat <<'JSON'
{
  "name": "hello",
  "description": "Example alter plugin",
  "tools": [
    {
      "name": "greet",
      "description": "Return predictable greeting JSON",
      "inputSchema": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          }
        },
        "required": [
          "name"
        ]
      }
    }
  ]
}
JSON
    ;;
  doctor)
    cat <<'JSON'
{
  "ok": true,
  "plugin": "hello"
}
JSON
    ;;
  invoke)
    if [ "$#" -ne 2 ]; then
      echo "usage: alter-hello invoke <json>" >&2
      exit 2
    fi
    printf '%s' "$2" | awk -f "$plugin_dir/invoke.awk"
    ;;
  *)
    echo "usage: alter-hello <manifest|doctor|invoke>" >&2
    exit 2
    ;;
esac
